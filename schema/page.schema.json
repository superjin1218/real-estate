{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Real Estate Field Wiki Page",
  "type": "object",
  "required": ["id", "title", "type", "tags", "source", "updated_at", "related_pages", "body"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9A-Za-z가-힣][0-9A-Za-z가-힣-]*$"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["region", "property", "field_note", "checklist", "trade_summary", "ontology"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "related_pages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "body": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "district": {
      "type": "string"
    },
    "lat_lng": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "ontology_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scores": {
      "type": "object"
    }
  }
}
